# ============================================================================
# CostPro — Variables de entorno (PLANTILLA — copiar a .env y rellenar)
# ============================================================================
# ⚠️ NO commitear credenciales reales. Este archivo es solo una plantilla.

# Database (Prisma)
DATABASE_URL=file:./db/custom.db

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
SUPABASE_ACCESS_TOKEN=YOUR_ACCESS_TOKEN_HERE

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# SECURITY: Dev bypass MUST be false in production.
ENABLE_DEV_BYPASS=false

# CSRF: Comma-separated allowed domains
# Development:
CSRF_ALLOWED_DOMAINS=.space-z.ai
# Production:
#   CSRF_ALLOWED_DOMAINS=yourdomain.com,*.vercel.app,.space-z.ai

# AI Providers
ZAI_API_KEY=your-zai-api-key-here
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=your-openai-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# App
NODE_ENV=development
PORT=3000

# Vercel (opcional)
VERCEL_TOKEN=your-vercel-token-here

# Sentry (opcional)
SENTRY_DSN=

# OpenTelemetry (opcional)
OTEL_ENABLED=false
