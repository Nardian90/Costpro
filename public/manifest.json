{
  "name": "CostPro - Sistema de Gestión Integral",
  "short_name": "CostPro",
  "description": "Plataforma completa para gestión de inventario, ventas y administración de tiendas.",
  "id": "/",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#121212",
  "theme_color": "#16a34a",
  "orientation": "any",
  "dir": "ltr",
  "lang": "es",
  "categories": ["business", "finance", "productivity"],
  "permissions_policy": {
    "camera": ["self"],
    "microphone": [],
    "geolocation": []
  },
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/storefront-construccion-banner.png",
      "sizes": "1344x768",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "CostPro - Vista de escritorio"
    },
    {
      "src": "/mobile-screenshot.png",
      "sizes": "720x1280",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "CostPro - Vista móvil"
    }
  ],
  "shortcuts": [
    {
      "name": "Nueva Venta",
      "short_name": "Venta",
      "description": "Iniciar una nueva venta en el POS",
      "url": "/pos",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Inventario",
      "short_name": "Inventario",
      "description": "Ver estado del inventario",
      "url": "/dashboard/inventory",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://costpro4.vercel.app/manifest.json"
    }
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "display_override": ["standalone", "fullscreen", "window-controls-overlay"],
  "scope": "/",
  "scope_extensions": [
    {
      "type": "window",
      "origin": "https://costpro4.vercel.app"
    }
  ],
  "file_handlers": [
    {
      "action": "/dashboard/inventory",
      "accept": {
        "text/csv": [".csv"]
      }
    }
  ],
  "launch_handler": {
    "client_mode": "auto"
  },
  "protocol_handlers": [
    {
      "protocol": "web+costpro",
      "url": "/?link=%s"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "note_taking": {
    "new_note_url": "/pos"
  }
}
