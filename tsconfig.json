{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    // FIX-BUG-SEC-004: Removed "noImplicitAny": false — contradicts "strict": true
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "examples",
    "skills",
    "scripts/analyze-*.ts",
    "scripts/check-*.ts",
    "scripts/analyze-header.ts",
    "scripts/analyze-header2.ts",
    "scripts/analyze-screenshot.ts",
    "scripts/analyze-screenshot2.ts",
    "scripts/analyze-screenshot3.ts",
    "scripts/analyze-tg.ts",
    "scripts/analyze-tg3.ts",
    "scripts/check-raw.ts",
    "scripts/check-telegram-msgs.ts",
    "src/lib/db.ts"
  ]
}
